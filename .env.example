# ── PostgreSQL + TimescaleDB ────────────────────────────────────────────────
# A single timescale/timescaledb container holds both the relational data and
# the time-series ping history. The URL is assembled in app/core/config.py.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=network
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Optional: set DATABASE_URL to override the parts above entirely, e.g.
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db

# ── Redis (current-state cache + pub/sub bus) ───────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a real key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Ping scheduler ────────────────────────────────────────────────────────────
PING_INTERVAL_SECONDS=30
# ICMP packets per check; device is alive if at least one replies
PING_COUNT=3
# Consecutive failed checks before OFFLINE. 1st fail → UNKNOWN (yellow), Nth → OFFLINE (red)
FLAP_THRESHOLD=2
PING_TIMEOUT_SECONDS=1
# How devices are probed:
#   system  → OS `ping` command (works on Windows WITHOUT admin) — recommended
#   icmplib → raw ICMP (faster, but needs admin / CAP_NET_RAW)
PING_METHOD=system
# true → disable probing; status is set only via the /simulate endpoint (demo)
SIMULATION_MODE=false

# ── Collector / adaptive scheduling ───────────────────────────────────────────
# Probing runs in a separate `collector` process by default; set true to also run
# it inside the API (all-in-one local dev).
EMBEDDED_COLLECTOR=true
# Slow cadence for healthy devices; fast cadence for recently-flapping ones.
PING_FAST_INTERVAL_SECONDS=5
PING_VOLATILE_WINDOW_SECONDS=120

# ── Alerting / escalation (email via SMTP) ────────────────────────────────────
ALERT_ENABLED=false
ALERT_AFTER_SECONDS=120         # device must stay down this long before alerting
ALERT_CRITICAL_ONLY=true        # only critical devices trigger alerts
ALERT_CHECK_INTERVAL_SECONDS=30
SMTP_HOST=                      # internal mail relay host
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=netmon@example.com
SMTP_TLS=false
ALERT_EMAIL_TO=                 # comma-separated recipients

# ── Seed data (used by seed.py) ───────────────────────────────────────────────
DEFAULT_MANAGER_EMAIL=admin@example.com
DEFAULT_MANAGER_PASSWORD=changeme

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
