# ── MSSQL (SQL Server) ──────────────────────────────────────────────────────
# The connection string is assembled from these parts in app/core/config.py.
# A named instance such as  localhost\SQLEXPRESS  works as-is.
MSSQL_SERVER=localhost\SQLEXPRESS
MSSQL_DATABASE=network
MSSQL_USER=sa
MSSQL_PASSWORD=changeme
# Use "ODBC Driver 18 for SQL Server" if you installed Driver 18 instead.
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
MSSQL_ENCRYPT=yes
MSSQL_TRUST_CERT=yes

# Optional: set DATABASE_URL to override the parts above entirely, e.g.
# DATABASE_URL=mssql+aioodbc://user:pass@host:1433/db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=yes

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a real key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Ping scheduler ────────────────────────────────────────────────────────────
PING_INTERVAL_SECONDS=30
# ICMP packets per check; device is alive if at least one replies
PING_COUNT=3
# Consecutive failed checks before OFFLINE. 1st fail → UNKNOWN (yellow), Nth → OFFLINE (red)
FLAP_THRESHOLD=2
PING_TIMEOUT_SECONDS=1
# How devices are probed:
#   system  → OS `ping` command (works on Windows WITHOUT admin) — recommended
#   icmplib → raw ICMP (faster, but needs admin / CAP_NET_RAW)
PING_METHOD=system
# true → disable probing; status is set only via the /simulate endpoint (demo)
SIMULATION_MODE=false

# ── Seed data (used by seed.py) ───────────────────────────────────────────────
DEFAULT_MANAGER_EMAIL=admin@example.com
DEFAULT_MANAGER_PASSWORD=changeme

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
