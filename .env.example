# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=netmon
POSTGRES_PASSWORD=changeme
POSTGRES_DB=netmon

# asyncpg URL — keep host "postgres" inside Docker, "localhost" for local dev
DATABASE_URL=postgresql+asyncpg://netmon:changeme@postgres:5432/netmon

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a real key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Ping scheduler ────────────────────────────────────────────────────────────
# How often (seconds) all enabled devices are pinged
PING_INTERVAL_SECONDS=30
# Consecutive ICMP failures before status flips to OFFLINE
FLAP_THRESHOLD=3

# ── Seed data (used by seed.py) ───────────────────────────────────────────────
DEFAULT_MANAGER_EMAIL=admin@example.com
DEFAULT_MANAGER_PASSWORD=changeme

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
